# Agnes API key 配置模板（复制为 .env 并填入真实 key）
#
# ⚠️ 安全提醒：
# 1. .env 已在 .gitignore 中，不会被 git 追踪
# 2. 不要把真实 key commit 到任何仓库
# 3. 文件权限建议 chmod 600 .env
#
# 用法（任选其一）：
#   export $(cat .env | xargs) && python3 scripts/agnes_image.py generate ...
#   或：在 shell rc 里 source .env
#   或：直接 export AGNES_API_KEY=...

# 单 key
AGNES_API_KEY="sk-your-key-here"

# 多 key（逗号分隔，自动轮换；image 和 video 共享 quota，建议 ≥2 个 key）
# AGNES_API_KEY="sk-key-a,sk-key-b,sk-key-c"

# 可选：自定义 API base（默认 https://apihub.agnes-ai.com）
# AGNES_API_BASE="https://apihub.agnes-ai.com"